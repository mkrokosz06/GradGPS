# Copy this to .env and fill in values

# ── Local development ──
DYNAMODB_ENDPOINT=http://localhost:8000
S3_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=testtest
AWS_DEFAULT_REGION=us-east-1

# ── S3 bucket for transcript PDFs ──
S3_BUCKET=degreecheck-transcripts

# ── MinIO container credentials (docker-compose) ──
# These default to test/testtest. To override, set them in a ROOT-level .env
# (next to docker-compose.yml, NOT this file) so Compose picks them up, and keep
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY above matching — boto3 uses those to
# authenticate to MinIO.
# MINIO_ROOT_USER=test
# MINIO_ROOT_PASSWORD=testtest

# ── Production (real AWS) — remove the endpoint vars above ──
# AWS_ACCESS_KEY_ID=your_real_key
# AWS_SECRET_ACCESS_KEY=your_real_secret
# AWS_DEFAULT_REGION=us-east-1

# ── CORS ──
# Comma-separated allowlist of browser origins. Defaults to Expo dev origins.
# Native Expo Go traffic is not subject to CORS; this only affects web/browser.
# CORS_ORIGINS=https://app.gradgps.example

# ── Auth ──
# Dev bypass: accept the legacy x-user-id header WITHOUT token verification.
# For local development only — NEVER set in production.
AUTH_DEV_BYPASS=1

# Comma-separated OAuth client IDs accepted as token audience.
# Google: the iOS / Android / Web client IDs from Google Cloud console.
# Apple:  the app bundle ID (and Service ID if using web flow).
GOOGLE_CLIENT_IDS=your_ios_client_id,your_android_client_id,your_web_client_id
APPLE_CLIENT_IDS=com.yourcompany.gradgps

# Comma-separated provider-scoped user ids allowed on /admin/*
# (find yours in the users table after first sign-in), e.g. google:1234567890
ADMIN_USER_IDS=

# ── Official transcript detection ──
# Set to 1 to enable the consent gate: official transcripts get a 409 requiring
# acknowledge_official on re-submit. Unset = shadow mode (detect + log only,
# never block) — used to validate the false-positive rate before rollout.
# OFFICIAL_DETECT=1
