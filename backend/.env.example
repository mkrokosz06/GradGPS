# Copy this to .env and fill in values

# ── Local development ──
DYNAMODB_ENDPOINT=http://localhost:8000
S3_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=testtest
AWS_DEFAULT_REGION=us-east-1

# ── S3 bucket for transcript PDFs ──
S3_BUCKET=degreecheck-transcripts

# ── Production (real AWS) — remove the endpoint vars above ──
# AWS_ACCESS_KEY_ID=your_real_key
# AWS_SECRET_ACCESS_KEY=your_real_secret
# AWS_DEFAULT_REGION=us-east-1

# ── Auth ──
# Local dev: accept the legacy x-user-id header without token verification.
# NEVER set this in production.
AUTH_DEV_BYPASS=1

# Comma-separated OAuth client IDs (fill in after Google Cloud console setup)
GOOGLE_CLIENT_IDS=your_google_client_id.apps.googleusercontent.com
APPLE_CLIENT_IDS=

# Comma-separated provider-scoped admin ids, e.g. google:1234567890
ADMIN_USER_IDS=

# ── Official-transcript consent gate ──
# When 1, a detected official transcript is blocked with a 409 until the client
# re-submits with acknowledge_official=true (drives the mobile consent dialog).
# When unset/0 = shadow mode: detect + parse + log, but never 409.
OFFICIAL_DETECT=1
