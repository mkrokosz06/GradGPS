SLACK_ENABLED=1

# Outbound reports (Incoming Webhook) — create in Slack app → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/ME/PLEASE

# Inbound bot (Socket Mode) — see agents/docs/slack-setup.md
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_DEFAULT_CHANNEL=#gradgps-agents

# Optional message prefix in Slack
# SLACK_MESSAGE_PREFIX=GradGPS

# Optional: real official transcript PDF for e2e detector test
# OFFICIAL_SAMPLE_PDF=C:/path/to/official.pdf
